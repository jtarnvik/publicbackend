<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="012-1" author="jesper">
        <createTable tableName="deviation_interpretations">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="hash" type="varchar(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_deviation_interpretations_hash"/>
            </column>
            <column name="deviation_text" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="from_date" type="DATE"/>
            <column name="to_date" type="DATE"/>
            <column name="accessibility" type="BOOLEAN"/>
            <column name="delays" type="BOOLEAN"/>
            <column name="cancelations" type="BOOLEAN"/>
            <column name="during_commute" type="BOOLEAN"/>
            <column name="during_weekend" type="BOOLEAN"/>
            <column name="during_night" type="BOOLEAN"/>
            <column name="importance" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="interpretation_notes" type="varchar(2000)"/>
            <column name="create_date" type="DATETIME"/>
            <column name="latest_update" type="DATETIME"/>
        </createTable>
        <sql dbms="postgresql">ALTER TABLE deviation_interpretations ENABLE ROW LEVEL SECURITY;</sql>
    </changeSet>

    <changeSet id="012-2" author="jesper">
        <insert tableName="id_gen">
            <column name="id" valueNumeric="5"/>
            <column name="gen_name" value="deviation_interpretations_gen"/>
            <column name="gen_value" valueNumeric="10000"/>
        </insert>
    </changeSet>

</databaseChangeLog>
