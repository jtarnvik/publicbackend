<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="029-1" author="jesper">
        <createTable tableName="gtfs_stop_time">
            <column name="trip_id" type="VARCHAR(50)">
                <constraints primaryKey="true" primaryKeyName="pk_gtfs_stop_time" nullable="false"/>
            </column>
            <column name="stop_sequence" type="INT">
                <constraints primaryKey="true" primaryKeyName="pk_gtfs_stop_time" nullable="false"/>
            </column>
            <column name="stop_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="arrival_time" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="departure_time" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="shape_dist_traveled" type="DOUBLE"/>
            <column name="stop_headsign" type="VARCHAR(100)"/>
        </createTable>
        <sql dbms="postgresql">ALTER TABLE gtfs_stop_time ENABLE ROW LEVEL SECURITY;</sql>
    </changeSet>

</databaseChangeLog>
