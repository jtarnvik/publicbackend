<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="027-1" author="jesper">
        <createTable tableName="gtfs_route">
            <column name="route_id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="route_short_name" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="route_long_name" type="VARCHAR(200)"/>
            <column name="route_type" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql dbms="postgresql">ALTER TABLE gtfs_route ENABLE ROW LEVEL SECURITY;</sql>
    </changeSet>

</databaseChangeLog>
