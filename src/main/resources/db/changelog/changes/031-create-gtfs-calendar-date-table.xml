<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="031-1" author="jesper">
        <createTable tableName="gtfs_calendar_date">
            <column name="service_id" type="VARCHAR(50)">
                <constraints primaryKey="true" primaryKeyName="pk_gtfs_calendar_date" nullable="false"/>
            </column>
            <column name="service_date" type="DATE">
                <constraints primaryKey="true" primaryKeyName="pk_gtfs_calendar_date" nullable="false"/>
            </column>
            <column name="exception_type" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql dbms="postgresql">ALTER TABLE gtfs_calendar_date ENABLE ROW LEVEL SECURITY;</sql>
    </changeSet>

</databaseChangeLog>
