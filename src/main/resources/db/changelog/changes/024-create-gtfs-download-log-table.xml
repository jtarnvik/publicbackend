<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="024-1" author="jesper">
        <createTable tableName="gtfs_download_log">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="VARCHAR(2000)"/>
            <column name="download_start_time" type="DATETIME"/>
            <column name="unzip_start_time" type="DATETIME"/>
            <column name="parse_start_time" type="DATETIME"/>
            <column name="end_time" type="DATETIME"/>
            <column name="create_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="latest_update" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql dbms="postgresql">ALTER TABLE gtfs_download_log ENABLE ROW LEVEL SECURITY;</sql>

        <insert tableName="id_gen">
            <column name="id" valueNumeric="10"/>
            <column name="gen_name" value="gtfs_download_log_gen"/>
            <column name="gen_value" valueNumeric="10000"/>
        </insert>
    </changeSet>

</databaseChangeLog>
